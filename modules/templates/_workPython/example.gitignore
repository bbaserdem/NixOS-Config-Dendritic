# ========================================
# BMAD Policy
# ========================================

# BMAD framework: ignore by default, but keep module configs and BMAD catalog.
_bmad/**
!_bmad/
!_bmad/_config/
!_bmad/_config/**
!_bmad/_memory/
!_bmad/_memory/**
!_bmad/*/
!_bmad/*/config.yaml
!_bmad/bmm/
!_bmad/bmm/workflows/
!_bmad/bmm/workflows/4-implementation/
!_bmad/bmm/workflows/4-implementation/code-review/
!_bmad/bmm/workflows/4-implementation/create-story/
!_bmad/bmm/workflows/bmad-quick-flow/
!_bmad/bmm/workflows/bmad-quick-flow/quick-dev/
!_bmad/bmm/workflows/bmad-quick-flow/quick-dev/steps/
!_bmad/bmm/workflows/4-implementation/code-review/instructions.xml
!_bmad/bmm/workflows/4-implementation/code-review/checklist.md
!_bmad/bmm/workflows/4-implementation/create-story/instructions.xml
!_bmad/bmm/workflows/4-implementation/create-story/checklist.md
!_bmad/bmm/workflows/bmad-quick-flow/quick-dev/workflow.md
!_bmad/bmm/workflows/bmad-quick-flow/quick-dev/steps/step-01-mode-detection.md
!_bmad/bmm/workflows/bmad-quick-flow/quick-dev/steps/step-02-context-gathering.md
!_bmad/bmm/workflows/bmad-quick-flow/quick-dev/steps/step-03-execute.md
!_bmad/bmm/workflows/bmad-quick-flow/quick-dev/steps/step-04-self-check.md
!_bmad/bmm/workflows/bmad-quick-flow/quick-dev/steps/step-05-adversarial-review.md
!_bmad/bmm/workflows/bmad-quick-flow/quick-dev/steps/step-06-resolve-findings.md

# BMAD generated outputs: ignore everything by default, then allow durable artifacts.
_bmad-output/*
!_bmad-output/bmb-creations/
!_bmad-output/bmb-creations/**
!_bmad-output/prompts/
!_bmad-output/prompts/**
!_bmad-output/planning-artifacts/
!_bmad-output/planning-artifacts/**
!_bmad-output/implementation-artifacts/
!_bmad-output/implementation-artifacts/**
!_bmad-output/test-artifacts/
!_bmad-output/test-artifacts/**
!_bmad-output/project-context.md

# High-churn exploratory/generated outputs are ignored.
_bmad-output/brainstorming/
_bmad-output/bmb-creations/
_bmad-output/planning-artifacts/research/
